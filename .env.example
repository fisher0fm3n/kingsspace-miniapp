# Public base URL of this app — used to build the KingsChat OAuth redirect_uri
# (`${NEXT_PUBLIC_APP_URL}/auth/callback`).
#
# This value MUST exactly match a redirect URI registered in the KingsChat
# OAuth app (scheme, host, no trailing slash). If unset, the app falls back to
# the browser's window.location.origin.
#
# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD time, so set this before
# `next build` in each environment.
#
#   Local dev:  http://localhost:3200
#   Production: https://your-live-domain.com
NEXT_PUBLIC_APP_URL=https://your-live-domain.com

# Where in-app account deletion requests are forwarded (POSTed as JSON) — e.g.
# a CeFlix ops endpoint, ticketing system, or Slack/email webhook. If unset,
# the app falls back to opening a pre-filled email to SUPPORT_EMAIL
# (src/lib/config.ts) so requests are never dropped.
DELETION_REQUEST_WEBHOOK_URL=
